# ═══════════════════════════════════════════════════════════════════════════════
# CHATBOT BCETD Agent — Environment Configuration
# Member 1 Deliverable: Infrastructure & DevOps Lead
#
# SETUP:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in required values (marked with ← REQUIRED)
#   3. Change all default passwords before deploying to production
#
# SECURITY:
#   • NEVER commit .env to Git (it's in .gitignore)
#   • Rotate all passwords before production deployment
#   • Store production secrets in a vault (HashiCorp Vault, Docker Secrets, etc.)
# ═══════════════════════════════════════════════════════════════════════════════


# ─── LLM API ─────────────────────────────────────────────────────────────────
# Required if using OpenAI models (GPT-4o-mini, text-embedding-3-small)
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-api-key-here             # ← REQUIRED (unless using Ollama only)


# ─── n8n (Workflow Engine) ───────────────────────────────────────────────────
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
N8N_AUTH_ACTIVE=true
N8N_USER=admin
N8N_PASSWORD=changeme_n8n                          # ← CHANGE IN PRODUCTION


# ─── PostgreSQL (Analytics Database) ─────────────────────────────────────────
POSTGRES_DB=chatbot_stats
POSTGRES_USER=chatbot_user
POSTGRES_PASSWORD=changeme_postgres                # ← CHANGE IN PRODUCTION
POSTGRES_PORT=5432


# ─── Qdrant (Vector Database) ────────────────────────────────────────────────
QDRANT_PORT=6333


# ─── Ollama (Local LLM — Optional) ──────────────────────────────────────────
# Start with:  docker compose --profile ollama up -d
# Then pull models:
#   docker exec bcetd-ollama ollama pull llama3.1
#   docker exec bcetd-ollama ollama pull nomic-embed-text
OLLAMA_PORT=11434


# ─── Frontend (Chat UI + Admin Dashboard) ────────────────────────────────────
FRONTEND_PORT=3000


# ─── Grafana (Analytics Dashboards — Optional) ───────────────────────────────
# Start with:  docker compose --profile monitoring up -d
GRAFANA_PORT=3001
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin                             # ← CHANGE IN PRODUCTION


# ─── Documents Path ──────────────────────────────────────────────────────────
# Local folder containing ULBS PDF/DOCX/TXT documents for ingestion
# This folder is mounted read-only into the n8n container at /data/documents/
DOCUMENTS_PATH=./data/documents


# ─── Timezone ────────────────────────────────────────────────────────────────
TIMEZONE=Europe/Bucharest


# ─── Backup (Member 4) ──────────────────────────────────────────────────────
BACKUP_DIR=./backups/postgres
BACKUP_RETENTION_DAYS=30
